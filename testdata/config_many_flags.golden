{
  "auditlog": "",
  "autocalibration": false,
  "autocalibration_keyword": "FUZZ",
  "autocalibration_perhost": false,
  "autocalibration_strategies": [
    "basic"
  ],
  "autocalibration_strings": [],
  "colors": false,
  "cmdline": "ffuf -u https://example.org/FUZZ -w /tmp/wl.txt -x http://127.0.0.1:8080 -replay-proxy http://127.0.0.1:9090 -sni example.com -timeout 15 -rate 50 -recursion -recursion-depth 3 -recursion-strategy greedy -of json -od /tmp/out -maxtime 60 -json -r -raw -http2 -ic -D -sf",
  "configfile": "",
  "postdata": "",
  "debuglog": "",
  "delay": {
    "value": "0.00"
  },
  "dirsearch_compatibility": true,
  "encoders": [],
  "extensions": [],
  "fmode": "or",
  "follow_redirects": true,
  "headers": {},
  "ignorebody": false,
  "ignore_wordlist_comments": true,
  "inputmode": "clusterbomb",
  "cmd_inputnum": 100,
  "inputproviders": [
    {
      "name": "wordlist",
      "keyword": "FUZZ",
      "value": "/tmp/wl.txt",
      "encoders": "",
      "template": ""
    }
  ],
  "inputshell": "",
  "json": true,
  "matchers": null,
  "mmode": "or",
  "maxtime": 60,
  "maxtime_job": 0,
  "method": "GET",
  "noninteractive": false,
  "outputdirectory": "/tmp/out",
  "outputfile": "",
  "outputformat": "",
  "OutputSkipEmptyFile": false,
  "proxyurl": "http://127.0.0.1:8080",
  "quiet": false,
  "rate": 50,
  "raw": true,
  "recursion": true,
  "recursion_depth": 3,
  "recursion_strategy": "greedy",
  "replayproxyurl": "http://127.0.0.1:9090",
  "requestfile": "",
  "requestproto": "https",
  "scraperfile": "",
  "scrapers": "all",
  "sni": "example.com",
  "stop_403": true,
  "stop_all": false,
  "stop_errors": false,
  "threads": 40,
  "timeout": 15,
  "url": "https://example.org/FUZZ",
  "verbose": false,
  "wordlists": [
    "/tmp/wl.txt"
  ],
  "http2": true,
  "client-cert": "",
  "client-key": "",
  "preflights": [],
  "postflights": [],
  "preflight_mode": "per-request",
  "preflight_error": "abort"
}

--- matchers after SetupFilters ---
matchers:
  status = 200-299,301,302,307,401,403,405,500
filters:

